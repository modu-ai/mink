{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "GOOSE brand design tokens — derived from visual-identity.md. Source of truth for all implementation (Web/Mobile/Desktop).",
  "$metadata": {
    "name": "goose-brand-tokens",
    "version": "1.0.0",
    "lastUpdated": "2026-04-23",
    "source": ".moai/project/brand/visual-identity.md"
  },
  "color": {
    "primary": {
      "50":  { "$value": "#FFF8E7", "$type": "color" },
      "100": { "$value": "#FFEFC2", "$type": "color" },
      "200": { "$value": "#FFE08A", "$type": "color" },
      "300": { "$value": "#FFCE4D", "$type": "color" },
      "500": { "$value": "#FFB800", "$type": "color", "$description": "Brand signature — primary CTA" },
      "600": { "$value": "#E6A300", "$type": "color" },
      "700": { "$value": "#B37F00", "$type": "color" },
      "900": { "$value": "#4D3600", "$type": "color" }
    },
    "secondary": {
      "50":  { "$value": "#F0F6F1", "$type": "color" },
      "200": { "$value": "#C8DFCA", "$type": "color" },
      "500": { "$value": "#6B9E74", "$type": "color" },
      "700": { "$value": "#406B47", "$type": "color" }
    },
    "accent": {
      "300": { "$value": "#F6A5B0", "$type": "color" },
      "500": { "$value": "#E56B7C", "$type": "color" }
    },
    "neutral": {
      "50":  { "$value": "#FAF8F4", "$type": "color", "$description": "Page background (light)" },
      "100": { "$value": "#F1EEE8", "$type": "color" },
      "200": { "$value": "#E2DDD2", "$type": "color" },
      "300": { "$value": "#C9C2B3", "$type": "color" },
      "400": { "$value": "#9D9587", "$type": "color" },
      "500": { "$value": "#6F685C", "$type": "color" },
      "600": { "$value": "#524C42", "$type": "color" },
      "700": { "$value": "#3A352E", "$type": "color" },
      "800": { "$value": "#252220", "$type": "color" },
      "900": { "$value": "#171513", "$type": "color", "$description": "Page background (dark)" },
      "950": { "$value": "#0B0A09", "$type": "color" }
    },
    "semantic": {
      "success": { "$value": "#4C9B6A", "$type": "color" },
      "warning": { "$value": "#E89A3C", "$type": "color" },
      "danger":  { "$value": "#D45A4F", "$type": "color" },
      "info":    { "$value": "#5B8FB5", "$type": "color" }
    }
  },
  "typography": {
    "fontFamily": {
      "primary":  { "$value": "Inter, Pretendard, -apple-system, system-ui, sans-serif", "$type": "fontFamily" },
      "display":  { "$value": "Fraunces, Pretendard, Georgia, serif", "$type": "fontFamily" },
      "mono":     { "$value": "'JetBrains Mono', 'D2Coding', ui-monospace, Menlo, monospace", "$type": "fontFamily" }
    },
    "fontWeight": {
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" }
    },
    "scale": {
      "display.xl": { "$value": { "fontSize": "72px", "lineHeight": 1.05, "fontWeight": 600 }, "$type": "typography" },
      "display.lg": { "$value": { "fontSize": "56px", "lineHeight": 1.10, "fontWeight": 600 }, "$type": "typography" },
      "display.md": { "$value": { "fontSize": "44px", "lineHeight": 1.15, "fontWeight": 600 }, "$type": "typography" },
      "heading.h1": { "$value": { "fontSize": "36px", "lineHeight": 1.20, "fontWeight": 600 }, "$type": "typography" },
      "heading.h2": { "$value": { "fontSize": "28px", "lineHeight": 1.30, "fontWeight": 600 }, "$type": "typography" },
      "heading.h3": { "$value": { "fontSize": "22px", "lineHeight": 1.35, "fontWeight": 500 }, "$type": "typography" },
      "body.lg":    { "$value": { "fontSize": "18px", "lineHeight": 1.60, "fontWeight": 400 }, "$type": "typography" },
      "body.md":    { "$value": { "fontSize": "16px", "lineHeight": 1.60, "fontWeight": 400 }, "$type": "typography" },
      "body.sm":    { "$value": { "fontSize": "14px", "lineHeight": 1.55, "fontWeight": 400 }, "$type": "typography" },
      "caption":    { "$value": { "fontSize": "12px", "lineHeight": 1.50, "fontWeight": 500 }, "$type": "typography" },
      "mono.md":    { "$value": { "fontSize": "14px", "lineHeight": 1.60, "fontWeight": 400 }, "$type": "typography" }
    },
    "letterSpacing": {
      "korean": { "$value": "-0.01em", "$type": "dimension" }
    }
  },
  "spacing": {
    "0":  { "$value": "0px",   "$type": "dimension" },
    "1":  { "$value": "4px",   "$type": "dimension" },
    "2":  { "$value": "8px",   "$type": "dimension" },
    "3":  { "$value": "12px",  "$type": "dimension" },
    "4":  { "$value": "16px",  "$type": "dimension", "$description": "Default gap" },
    "5":  { "$value": "24px",  "$type": "dimension" },
    "6":  { "$value": "32px",  "$type": "dimension" },
    "8":  { "$value": "48px",  "$type": "dimension" },
    "10": { "$value": "64px",  "$type": "dimension" },
    "12": { "$value": "96px",  "$type": "dimension" },
    "16": { "$value": "128px", "$type": "dimension" }
  },
  "layout": {
    "maxWidth": {
      "content":  { "$value": "1120px", "$type": "dimension" },
      "reading":  { "$value": "680px",  "$type": "dimension" }
    },
    "gutter": {
      "mobile":   { "$value": "16px", "$type": "dimension" },
      "desktop":  { "$value": "32px", "$type": "dimension" }
    }
  },
  "radius": {
    "sm":   { "$value": "6px",    "$type": "dimension" },
    "md":   { "$value": "12px",   "$type": "dimension", "$description": "Default — buttons, inputs" },
    "lg":   { "$value": "20px",   "$type": "dimension" },
    "xl":   { "$value": "32px",   "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },
  "shadow": {
    "sm": { "$value": "0 1px 2px rgba(77, 54, 0, 0.06)",   "$type": "shadow" },
    "md": { "$value": "0 4px 12px rgba(77, 54, 0, 0.08)",  "$type": "shadow", "$description": "Card default" },
    "lg": { "$value": "0 12px 32px rgba(77, 54, 0, 0.12)", "$type": "shadow" },
    "xl": { "$value": "0 24px 48px rgba(77, 54, 0, 0.16)", "$type": "shadow" }
  },
  "motion": {
    "duration": {
      "instant":    { "$value": "0ms",    "$type": "duration" },
      "acknowledge":{ "$value": "180ms",  "$type": "duration" },
      "settle":     { "$value": "320ms",  "$type": "duration" },
      "growth":     { "$value": "800ms",  "$type": "duration" },
      "breathing":  { "$value": "3200ms", "$type": "duration" }
    },
    "easing": {
      "snappy":   { "$value": "cubic-bezier(0.2, 0, 0, 1)",      "$type": "cubicBezier" },
      "standard": { "$value": "cubic-bezier(0.4, 0, 0.2, 1)",    "$type": "cubicBezier" },
      "sine":     { "$value": "cubic-bezier(0.4, 0, 0.6, 1)",    "$type": "cubicBezier" },
      "gentleOvershoot": { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "$type": "cubicBezier" }
    }
  },
  "zIndex": {
    "base":    { "$value": 0,    "$type": "number" },
    "dropdown":{ "$value": 100,  "$type": "number" },
    "sticky":  { "$value": 200,  "$type": "number" },
    "overlay": { "$value": 300,  "$type": "number" },
    "modal":   { "$value": 400,  "$type": "number" },
    "toast":   { "$value": 500,  "$type": "number" }
  },
  "breakpoint": {
    "sm":  { "$value": "640px",  "$type": "dimension" },
    "md":  { "$value": "768px",  "$type": "dimension" },
    "lg":  { "$value": "1024px", "$type": "dimension" },
    "xl":  { "$value": "1280px", "$type": "dimension" },
    "2xl": { "$value": "1536px", "$type": "dimension" }
  }
}
